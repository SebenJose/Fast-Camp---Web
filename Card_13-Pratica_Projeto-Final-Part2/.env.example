# Usado pelo docker-compose.yml (sobrescrito automaticamente pelo serviço
# "backend" para apontar pro serviço "db"). Defina aqui também para rodar
# localmente sem Docker, com um Postgres na sua máquina.
DATABASE_URL=postgresql+psycopg://organiza_ia:organiza_ia@localhost:5432/organiza_ia

SECRET_KEY=troque-por-uma-chave-secreta-forte
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_CODE_EXPIRE_MINUTES=15
ACCESS_TOKEN_COOKIE_NAME=access_token
COOKIE_SECURE=False

CORS_ORIGINS=http://localhost:3000

MAIL_USERNAME=organiza-ia@example.com
MAIL_PASSWORD=troque-pela-senha-do-smtp
MAIL_FROM=organiza-ia@example.com
MAIL_PORT=1025
MAIL_SERVER=mailpit
MAIL_STARTTLS=False
MAIL_SSL_TLS=False
MAIL_SUPPRESS_SEND=True
